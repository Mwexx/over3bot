COOLDOWN_SECONDS=10

# Market Analysis
TICK_HISTORY_SIZE=200
ANALYSIS_WINDOW=100
MIN_TICKS_TO_TRADE=50
MIN_MARKET_SCORE=0.55
MIN_STABILITY_SCORE=0.40
MIN_OVER3_RATE=0.52
SPIKE_THRESHOLD=3.0
MAX_SPIKE_RATIO=0.10
